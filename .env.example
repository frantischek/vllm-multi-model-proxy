INTERNAL_TOKEN=change-me
VLLM_URL=http://127.0.0.1:8000/v1/chat/completions
VLLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# Optional task-specific defaults (single-target mode)
VLLM_CHAT_URL=http://127.0.0.1:8000/v1/chat/completions
VLLM_CHAT_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_CAPTION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_IMAGE_URL=
VLLM_IMAGE_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLLM_TTS_URL=
VLLM_TTS_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# Optional multi-target mode (JSON object: alias -> task-specific URLs/models)
# VLLM_TARGETS_JSON={"default":{"chat_url":"http://127.0.0.1:8000/v1/chat/completions","chat_model":"Qwen/Qwen2.5-VL-7B-Instruct","caption_model":"Qwen/Qwen2.5-VL-7B-Instruct","image_url":"http://127.0.0.1:8000/v1/images/generations","image_model":"Qwen/Qwen-Image","tts_url":"http://127.0.0.1:8000/v1/audio/speech","tts_model":"Qwen/Qwen-TTS"},"fast":{"chat_url":"http://127.0.0.1:8001/v1/chat/completions","chat_model":"Qwen/Qwen2.5-VL-3B-Instruct"}}
# Optional explicit default target alias (if empty, uses "default" or first configured alias)
VLLM_DEFAULT_TARGET=

MAX_UPLOAD_MB=10
MAX_RESIZE=1536
JPEG_QUALITY=85

PROXY_TMP_DIR=/tmp/vllm-multi-model-proxy
PROXY_PUBLIC_BASE=http://127.0.0.1:9000

CAPTION_PROMPT=Beschreibe das Bild in genau 1 deutschen Satz. Nenne die wichtigsten Objekte (mind. 2), den Raum/Ort und auffällige Details. Keine Floskeln.

VLLM_TEMPERATURE=0.2
VLLM_MAX_TOKENS=80
VLLM_TIMEOUT_S=240
